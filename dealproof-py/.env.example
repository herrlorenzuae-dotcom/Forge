# DealProof configuration. Copy this file to ".env" and fill in your values.
#   cp .env.example .env
# The .env file is gitignored and never committed. Real shell environment
# variables take precedence over anything set here.

# Anthropic — enables model-drafted answers / question extraction.
ANTHROPIC_API_KEY=sk-ant-...
# DEALPROOF_MODEL=claude-opus-4-8

# Quantium (quantium.pe) — portfolio-company / fund / entity data.
# QUANTIUM_BASE_URL=https://api.quantium.pe
# QUANTIUM_API_KEY=

# YSolutions (ysolutions.legal) — beneficial ownership / Transparenzregister.
# YSOLUTIONS_BASE_URL=
# YSOLUTIONS_API_KEY=

# Clients (Mandanten): each gets its own login and a fully separate data store
# (projects, structures and the KYC Brain). Mock login for now; the layer is
# built to be swapped for SSO / real accounts later.
# DEALPROOF_TENANTS=ClientName:choose-a-password
# DEALPROOF_TENANTS=ClientA:pw1,ClientB:pw2

# Connector behaviour
# DEALPROOF_MOCK_CONNECTORS=1
# DEALPROOF_CONNECTOR_TIMEOUT=8
