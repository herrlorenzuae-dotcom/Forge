# Frontier model (required to draft answers; the app still runs without it —
# the KYC Brain answers from the existing corpus, and structure/org-chart work).
ANTHROPIC_API_KEY=

# Model override
KYC_MODEL=claude-opus-4-8

# Server
KYC_PORT=3000
KYC_HOST=127.0.0.1

# Storage
KYC_DB_PATH=./data/kyc.db

# Data connectors. 'mock' runs fully in-process from bundled sample data.
# Point at the real systems by implementing the Connector interface (see
# src/connectors/) or by wiring an MCP client to the Quantium / YSolutions
# MCP servers in src/mcp/.
KYC_CONNECTOR=mock

# Currency / Aktualität: structure data older than this many days is flagged
# stale by the Quantium verification pass.
KYC_STALE_DAYS=180

# Privacy: entity and UBO names are masked on-device before any frontier call.
# Set to 1 to also send jurisdictions (off by default — jurisdiction plus
# entity type can re-identify a small structure).
KYC_SEND_JURISDICTION=0
